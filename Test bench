module tb;

    reg clk;
    reg rst;
    reg start;
    reg [7:0] tx_data;
    reg miso;

    wire mosi;
    wire sclk;
    wire cs_n;
    wire done;
    wire [7:0] rx_data;

    spi_master dut (
        .clk(clk),
        .rst(rst),
        .start(start),
        .tx_data(tx_data),
        .miso(miso),
        .mosi(mosi),
        .sclk(sclk),
        .cs_n(cs_n),
        .done(done),
        .rx_data(rx_data)
    );

    always #5 clk = ~clk;

    initial begin
        $dumpfile("dump.vcd");
        $dumpvars(0, tb);

        clk = 0;
        rst = 1;
        start = 0;
        tx_data = 8'hA5;
        miso = 0;

        #20 rst = 0;

        #10 start = 1;
        #10 start = 0;

        // Slave sends 11001100
        #20 miso = 1;
        #20 miso = 1;
        #20 miso = 0;
        #20 miso = 0;
        #20 miso = 1;
        #20 miso = 1;
        #20 miso = 0;
        #20 miso = 0;

        #100 $finish;
    end

endmodule
